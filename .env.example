# ============================================================
# ARGOS — Configuration d'environnement
# ============================================================
# Copier ce fichier en .env et le remplir.
# NE JAMAIS committer .env dans Git.
# ============================================================

# ------------------------------------------------------------
# MODE DE TRADING — NE PAS MODIFIER SANS RÉFLEXION
# ------------------------------------------------------------

# Mode principal : "paper" uniquement pour l'instant
TRADING_MODE=paper

# Désactivé par défaut. Mettre à "true" uniquement après
# validation manuelle complète des conditions de passage en réel.
ENABLE_REAL_TRADING=false

# Désactivé par défaut. Extension YouHodler future.
ENABLE_YOUHODLER_REAL=false

# ------------------------------------------------------------
# LIMITES DE CAPITAL RÉEL (0 = aucun trading réel autorisé)
# ------------------------------------------------------------

MAX_REAL_CAPITAL_EUR=0
MAX_REAL_TRADES_PER_DAY=0
MAX_DAILY_REAL_LOSS_EUR=0

# Interdit via API — ne jamais mettre à true
ALLOW_WITHDRAWAL_PERMISSION=false

# ------------------------------------------------------------
# CLÉS API — DONNÉES DE MARCHÉ
# ------------------------------------------------------------

# CoinGecko (gratuit, sans clé pour le plan de base)
COINGECKO_API_KEY=

# Binance (lecture seule, optionnel — fallback si CoinGecko indisponible)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# YouHodler (futur — laisser vide)
YOUHODLER_API_KEY=
YOUHODLER_API_SECRET=

# ------------------------------------------------------------
# CONFIGURATION SYSTÈME
# ------------------------------------------------------------

# Intervalle entre chaque cycle d'analyse (minutes)
SCAN_INTERVAL_MINUTES=15

# Niveau de log : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Chemin de la base de données SQLite
DATABASE_PATH=data/argos.db

# Chemin des logs
LOG_PATH=logs/argos.log

# Chemin des rapports
REPORTS_PATH=reports/weekly

# Chemin des exports CSV
EXPORTS_PATH=exports
